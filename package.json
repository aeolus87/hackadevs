{
  "name": "aeokit-webapp",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "turbo run test",
    "test:coverage": "pnpm --filter @aeokit-webapp/server test:coverage",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:coverage": "pnpm test:coverage && pnpm test:e2e",
    "test:all": "pnpm test && pnpm test:e2e",
    "clean": "turbo daemon stop 2>/dev/null || true; rm -rf .turbo && pnpm -r exec -- sh -c 'rm -rf dist'",
    "clean:all": "turbo daemon stop 2>/dev/null || true; rm -rf .turbo node_modules && pnpm -r exec -- sh -c 'rm -rf dist node_modules'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  }
}
